export default {
  async fetch(request, env, ctx) {
    const url = new URL(request.url);
    const path = url.pathname;

    // =========================================================
    // 1. 首页 UI
    // =========================================================
    if (path === "/" || path === "") {
      const currentUrl = `https://${url.host}`;
      const htmlContent = `
        <!DOCTYPE html>
        <html lang="zh-CN">
        <head>
          <meta charset="utf-8">
          <meta name="viewport" content="width=device-width, initial-scale=1">
          <title>🐻 PKC 中转代理 - 小熊搭建</title>
          <style>
            :root { --primary-color: #ff9f43; --bg-color: #f7f9fc; --card-bg: #ffffff; --text-main: #2d3436; }
            body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background-color: var(--bg-color); color: var(--text-main); display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
            .container { background: var(--card-bg); width: 90%; max-width: 500px; padding: 40px; border-radius: 24px; box-shadow: 0 20px 40px rgba(0,0,0,0.05); text-align: center; border: 1px solid rgba(0,0,0,0.02); }
            .bear-avatar { font-size: 60px; margin-bottom: 15px; display: inline-block; filter: drop-shadow(0 5px 10px rgba(0,0,0,0.1)); }
            h1 { margin: 10px 0; font-size: 26px; font-weight: 800; color: #2d3436; }
            .status-badge { display: inline-flex; align-items: center; padding: 6px 16px; background: #ebffef; color: #20bf6b; border-radius: 30px; font-size: 13px; font-weight: 600; margin-bottom: 25px; }
            .status-dot { height: 8px; width: 8px; background-color: #20bf6b; border-radius: 50%; margin-right: 8px; box-shadow: 0 0 8px #20bf6b; }
            .description { color: #636e72; font-size: 15px; margin-bottom: 30px; line-height: 1.8; }
            .url-card { background: #f8f9fa; padding: 24px; border-radius: 18px; border: 1px solid #edf2f7; margin-bottom: 20px; }
            #proxyUrl { display: block; font-family: "SFMono-Regular", Consolas, monospace; color: #e67e22; font-size: 16px; word-break: break-all; margin-bottom: 20px; font-weight: 700; }
            .btn-copy { background: var(--primary-color); color: white; border: none; padding: 14px 30px; border-radius: 14px; font-weight: 600; cursor: pointer; transition: all 0.2s; width: 100%; font-size: 16px; box-shadow: 0 4px 15px rgba(255, 159, 67, 0.3); }
            .btn-copy:hover { background: #f39c12; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(255, 159, 67, 0.4); }
            .btn-copy:active { transform: translateY(0); }
            .footer { margin-top: 30px; font-size: 12px; color: #b2bec3; }
          </style>
        </head>
        <body>
          <div class="container">
            <div class="bear-avatar">🐻</div>
            <h1>PKC 中转代理</h1>
            <div class="status-badge"><span class="status-dot"></span> 节点运行中</div>
            <p class="description">这是由 <b>小熊</b> 为您搭建的专属中转<br>支持 GitHub、Fish Audio 与 FineShare 接口加速<br>有任何问题联系小熊v200ddbot</p>
            <div class="url-card">
              <span id="proxyUrl">${currentUrl}</span>
              <button class="btn-copy" onclick="copyToClipboard()" id="copyBtn">一键复制地址</button>
            </div>
          </div>
          <script>
            function copyToClipboard() {
              const urlText = document.getElementById('proxyUrl').innerText;
              const btn = document.getElementById('copyBtn');
              navigator.clipboard.writeText(urlText).then(() => {
                btn.innerText = '✅ 已成功复制';
                btn.style.background = '#20bf6b';
                btn.style.boxShadow = '0 4px 15px rgba(32, 191, 107, 0.3)';
                setTimeout(() => {
                  btn.innerText = '一键复制地址';
                  btn.style.background = '#ff9f43';
                  btn.style.boxShadow = '0 4px 15px rgba(255, 159, 67, 0.3)';
                }, 2000);
              });
            }
          </script>
        </body>
        </html>
      `;
      return new Response(htmlContent, { headers: { "Content-Type": "text/html; charset=utf-8" } });
    }

    // =========================================================
    // 2. 路由逻辑定义
    // =========================================================

    let targetUrl = null;
    let targetHost = null;
    let shouldCache = false;
    let noCache = false;
    let handleCors = false;
    let forceMethod = null;

    // --- A. GitHub Raw ---
    if (path.startsWith("/raw/")) {
      targetHost = "raw.githubusercontent.com";
      targetUrl = `https://${targetHost}${path}`;
    }

    // --- B. Fish Audio ---
    else if (path.startsWith("/v1/tts")) {
      targetHost = "api.fish.audio";
      targetUrl = `https://${targetHost}/v1/tts`;
      forceMethod = "POST";
    }

    // --- C. FineVoice 新 TTS 接口 ---
    else if (path.startsWith("/v1/audio/speech-synthesis")) {
      targetHost = "apis.finevoice.ai";
      targetUrl = `https://${targetHost}/v1/audio/speech-synthesis`;
      forceMethod = "POST";
      handleCors = true;
    }

    // --- D. FineVoice 任务轮询接口 (异步TTS) ---
    else if (path.startsWith("/v1/task/")) {
      targetHost = "apis.finevoice.ai";
      targetUrl = `https://${targetHost}${path}`;  // 保留完整路径
      handleCors = true;
      // 轮询是 GET，不设置 forceMethod
    }

    // --- E. FineShare 旧版 FV 转语音 (保留兼容) ---
    else if (path.startsWith("/v1/text-to-speech")) {
      targetHost = "converter.fineshare.net";
      targetUrl = `https://${targetHost}/api/fsmstexttospeech`;
      forceMethod = "POST";
      handleCors = true;
    }

    // --- F. FineShare 旧版直接路径 ---
    else if (path.startsWith("/api/fsmstexttospeech")) {
      targetHost = "converter.fineshare.net";
      targetUrl = `https://${targetHost}/api/fsmstexttospeech`;
      forceMethod = "POST";
      handleCors = true;
    }

    // --- G. 音频缓存 ---
    else if (path.startsWith("/tts-generated-voices/")) {
      targetHost = "dlaudio.fineshare.net";
      targetUrl = `https://${targetHost}${path}`;
      shouldCache = true;
    }

    // --- H. 通用音频下载 ---
    else if (path.startsWith("/fvdlaudio/")) {
      targetHost = "dlaudio.fineshare.net";
      const newPath = path.replace("/fvdlaudio/", "/");
      targetUrl = `https://${targetHost}${newPath}`;
      shouldCache = true;
    }

    // --- I. 签到/API ---
    else if (path.startsWith("/fvapi/")) {
      targetHost = "aivoiceover.fineshare.net";
      const newPath = path.replace("/fvapi/", "/api/");
      targetUrl = `https://${targetHost}${newPath}${url.search}`;
      handleCors = true;
      noCache = true;
    }

    // --- J. Usage API ---
    else if (path.startsWith("/fvusageapi/")) {
      targetHost = "usage.fineshare.net";
      const newPath = path.replace("/fvusageapi/", "/api/");
      targetUrl = `https://${targetHost}${newPath}${url.search}`;
      handleCors = true;
      noCache = true;
    }

    // =========================================================
    // 3. 执行请求转发
    // =========================================================

    if (targetUrl) {
      // OPTIONS 预检
      if (handleCors && request.method === "OPTIONS") {
        return new Response(null, {
          status: 204,
          headers: {
            "Access-Control-Allow-Origin": "*",
            "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
            "Access-Control-Allow-Headers": "DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization",
            "Access-Control-Max-Age": "86400"
          }
        });
      }

      // 构建请求头
      const newHeaders = new Headers();
      for (const [key, value] of request.headers.entries()) {
        const lowerKey = key.toLowerCase();
        if (lowerKey.startsWith("cf-")) continue;
        newHeaders.set(key, value);
      }

      newHeaders.set("Host", targetHost);
      newHeaders.set("Referer", `https://${targetHost}/`);
      const clientIp = request.headers.get("CF-Connecting-IP") || "0.0.0.0";
      newHeaders.set("X-Real-IP", clientIp);
      newHeaders.set("X-Forwarded-For", clientIp);
      newHeaders.set("X-Forwarded-Proto", "https");

      if (forceMethod === "POST" || request.method === "POST") {
        if (!newHeaders.has("Content-Type")) newHeaders.set("Content-Type", "application/json");
        if (!newHeaders.has("Accept")) newHeaders.set("Accept", "application/json");
      }

      try {
        const method = forceMethod || request.method;
        const body = (method === "GET" || method === "HEAD") ? null : request.body;

        const modifiedRequest = new Request(targetUrl, {
          method, headers: newHeaders, body, redirect: "follow"
        });

        const response = await fetch(modifiedRequest);
        const newResponse = new Response(response.body, response);

        // CORS
        newResponse.headers.set("Access-Control-Allow-Origin", "*");
        if (handleCors) {
          newResponse.headers.set("Access-Control-Allow-Methods", "GET, POST, OPTIONS");
        }

        // 缓存
        if (shouldCache) {
          newResponse.headers.set("Cache-Control", "public, max-age=86400");
          if (path.endsWith(".mp3")) newResponse.headers.set("Content-Type", "audio/mpeg");
        }
        if (noCache) {
          newResponse.headers.set("Cache-Control", "no-cache, no-store, must-revalidate");
        }

        return newResponse;
      } catch (err) {
        return new Response(`Proxy Error: ${err.message}`, { status: 502 });
      }
    }

    return new Response("Not Found", { status: 404 });
  }
};
